# Pin the exact n8n version tested with this project
N8N_VERSION=REPLACE_WITH_TESTED_VERSION

TZ=America/Bogota
GENERIC_TIMEZONE=America/Bogota

# Generate a long random value for the real .env file
N8N_ENCRYPTION_KEY=replace-with-a-long-random-value

# Public demo configuration
API_BASE_URL=https://api.example.com
FILES_API_BASE_URL=https://files.example.com
RESULT_SPREADSHEET_ID=replace-with-your-spreadsheet-id